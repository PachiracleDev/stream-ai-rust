# Opcional: ruta absoluta al .env si systemd no usa WorkingDirectory en la carpeta del proyecto
# RELAY_DOTENV_PATH=/opt/interview-relay/.env

# Upstream IA: cortar espera si el primer trozo útil modelo tarda más de estos segundos (default 10, clamp 1–600).
# RELAY_FIRST_CHUNK_DEADLINE_SECS=10
# Cuántos reintentos EXTRA además del primer intento HTTP (default 1 → máximo 2 llamadas upstream).
# RELAY_FIRST_CHUNK_RETRY_MAX=1
#
# Rendimiento por fase (colores en terminal). Activa solo al depurar latencia:
# RELAY_PERF_LOG=1
# Opcional si usas RUST_LOG restrictivo: incluye también relay_perf=info

# JWT & Rate Limit
RELAY_JWT_SECRET=secret
REDIS_URL=redis://127.0.0.1:6379
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW_SECS=60

# Server
PORT=3070

# Relay body JSON: **`"speed": "fast"`** (alias **`rapidez`**) → Groq ese turno (chat completions OpenAI-compat).
# GROQ_API_KEY=gsk_...
# Opcional (por defecto Groq oficial):
# GROQ_CHAT_COMPLETIONS_URL=https://api.groq.com/openai/v1/chat/completions
# Opcional (por defecto modelo Llama 3.1 8B instant):
# GROQ_FAST_MODEL=llama-3.1-8b-instant

# AI Provider Configuration
# Proveedor: "openai" (default), "claude", "anthropic" o "deepseek"
AI_PROVIDER=openai

# Claves de API según el proveedor
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...   # obligatoria si AI_PROVIDER=claude|anthropic
# DEEPSEEK_API_KEY=sk-...        # obligatoria si AI_PROVIDER=deepseek

# DeepSeek: URI completa del endpoint chat completions (opcional; default API oficial)
# DEEPSEEK_CHAT_COMPLETIONS_URL=https://api.deepseek.com/chat/completions
# Pensamiento extendido ("thinking"): puede retrasar el primer token útil para el cliente.
# Para desactivarlo en la petición: DEEPSEEK_DISABLE_THINKING=1 o DEEPSEEK_THINKING_MODE=disabled

# Modelo (INTERVIEW_AGENT_MODEL): se usa tal cual en la API del proveedor activo
# OpenAI default: gpt-4o-mini
# Claude default: claude-sonnet-4-20250514
# DeepSeek default: deepseek-v4-flash  (también ej.: deepseek-v4-pro)
INTERVIEW_AGENT_MODEL=gpt-4o-mini

# Techo máximo de tokens de salida (64–4096, default si no existe: 512).
# Opcionalmente el cliente puede enviar en cada POST `max_output_tokens` o `maxOutputTokens`;
# ese valor no puede superar este techo ni bajar de 64 (se recorta automáticamente).
INTERVIEW_AGENT_MAX_TOKENS=512

# Temperatura (default: 0.6). OpenAI y DeepSeek; Anthropic no envía este campo en modelos actuales.
INTERVIEW_AGENT_TEMPERATURE=0.6

# Máximo de mensajes en el historial (default: 10, min: 4, max: 32)
INTERVIEW_AGENT_MAX_HISTORY=10
