# RELAY_DOTENV_PATH=/opt/interview-relay/.env
# RELAY_PROMPTS_DIR=prompts

# RELAY_FIRST_CHUNK_DEADLINE_SECS=10
# RELAY_FIRST_CHUNK_RETRY_MAX=1
# RELAY_PERF_LOG=1

RELAY_JWT_SECRET=secret

# Rate limit: redis | memory | disabled
# - redis: requiere REDIS_URL (default)
# - memory: contador en proceso, sin Redis
# - disabled: sin límite ni conexión Redis
RATE_LIMIT_BACKEND=redis
REDIS_URL=redis://127.0.0.1:6379
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW_SECS=60
PORT=3070

# ── API keys (solo la del proveedor que uses en MODEL_*) ──
OPENAI_API_KEY=
# URL completa del endpoint OpenAI/Azure. Dos formatos:
# Chat Completions: .../openai/v1/chat/completions?api-version=...
# Responses API (gpt-5.x vision): .../openai/responses?api-version=2025-04-01-preview
# OPENAI_CHAT_URL=https://TU_RECURSO.cognitiveservices.azure.com/openai/responses?api-version=2025-04-01-preview

ANTHROPIC_API_KEY=

DEEPSEEK_API_KEY=
# DEEPSEEK_URL=https://api.deepseek.com/chat/completions

GROQ_API_KEY=

# ── Modelo por agente: cambia solo MODEL_* (proveedor se infiere) ──
# Valores típicos:
#   groq                  → Groq (openai/gpt-oss-20b)
#   openai/gpt-oss-20b    → Groq (GPT-OSS 20B)
#   claude-opus-4-7       → Anthropic
#   DeepSeek-V4-Flash     → DeepSeek
#   gpt-5.4-nano          → OpenAI/Azure (OPENAI_CHAT_URL)

# Detector: extrae la última pregunta del entrevistador (JSON). Modelo pequeño y rápido.
MODEL_DETECTOR=groq
MAX_TOKENS_DETECTOR=80

MODEL_OPENER=groq
MAX_TOKENS_OPENER=120

MODEL_DEEPENER=groq
MAX_TOKENS_DEEPENER=350

MODEL_IMAGE_SOLVER=gpt-5.4-nano
MAX_TOKENS_IMAGE_SOLVER=4000

# Opcional
# DEEPSEEK_DISABLE_THINKING=1
INTERVIEW_AGENT_TEMPERATURE=0.6
INTERVIEW_AGENT_MAX_HISTORY=10
